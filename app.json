{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.gerald.swannonekeyfob",
  "version": "1.0.5",
  "compatibility": ">=12.1.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "SwannOne Key Fob",
    "nl": "SwannOne Key Fob"
  },
  "description": {
    "en": "Control your home with a press of your key fob.",
    "nl": "Bedien je huis met een druk op je sleutelhanger."
  },
  "category": [
    "security"
  ],
  "brandColor": "#1B3A57",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Gerald Lankamp",
    "email": "gerald.lankamp@gmail.com"
  },
  "source": "https://github.com/qan-ai/homey-swannone-keyfob",
  "bugs": {
    "url": "https://github.com/qan-ai/homey-swannone-keyfob/issues"
  },
  "support": "https://github.com/qan-ai/homey-swannone-keyfob/issues",
  "flow": {
    "triggers": [
      {
        "id": "key_away",
        "title": {
          "en": "Away button pressed",
          "nl": "Away-knop ingedrukt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=keyfob"
          }
        ]
      },
      {
        "id": "key_home",
        "title": {
          "en": "Home button pressed",
          "nl": "Home-knop ingedrukt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=keyfob"
          }
        ]
      },
      {
        "id": "key_panic",
        "title": {
          "en": "Panic button pressed",
          "nl": "Paniekknop ingedrukt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=keyfob"
          }
        ]
      },
      {
        "id": "key_sleep",
        "title": {
          "en": "Sleep button pressed",
          "nl": "Sleep-knop ingedrukt"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=keyfob"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "id": "keyfob",
      "name": {
        "en": "SwannOne Key Fob",
        "nl": "SwannOne Key Fob"
      },
      "class": "button",
      "capabilities": [
        "last_pressed"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "zigbee"
      ],
      "images": {
        "small": "/drivers/keyfob/assets/images/small.png",
        "large": "/drivers/keyfob/assets/images/large.png",
        "xlarge": "/drivers/keyfob/assets/images/xlarge.png"
      },
      "zigbee": {
        "manufacturerName": "SwannONe",
        "productId": [
          "SWO-KEF1PA"
        ],
        "endpoints": {
          "1": {
            "clusters": [
              0
            ],
            "bindings": [
              1281
            ]
          }
        },
        "learnmode": {
          "instruction": {
            "en": "Hold the pair button on the back of the key fob until the LED flashes, then release. Keep the fob close to Homey while it is discovered.",
            "nl": "Houd de pairing-knop aan de achterkant van de key fob ingedrukt tot het lampje knippert en laat dan los. Houd de fob dicht bij Homey tijdens het zoeken."
          }
        }
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    }
  ],
  "widgets": {
    "status": {
      "name": {
        "en": "Key Fob status",
        "nl": "Sleutelhanger-status"
      },
      "height": 190,
      "settings": [
        {
          "id": "device",
          "type": "autocomplete",
          "title": {
            "en": "Key Fob",
            "nl": "Sleutelhanger"
          }
        }
      ],
      "api": {
        "getStatus": {
          "method": "POST",
          "path": "/status"
        }
      },
      "id": "status"
    }
  },
  "capabilities": {
    "last_pressed": {
      "type": "enum",
      "title": {
        "en": "Last pressed",
        "nl": "Laatst ingedrukt"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false,
      "values": [
        {
          "id": "home",
          "title": {
            "en": "Home",
            "nl": "Thuis"
          }
        },
        {
          "id": "away",
          "title": {
            "en": "Away",
            "nl": "Afwezig"
          }
        },
        {
          "id": "sleep",
          "title": {
            "en": "Night",
            "nl": "Nacht"
          }
        },
        {
          "id": "panic",
          "title": {
            "en": "Panic",
            "nl": "Paniek"
          }
        }
      ]
    }
  }
}